<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add
        name="iisnode"
        path="dist/index.js"
        verb="*"
        modules="iisnode"
      />
    </handlers>
    <rewrite>
      <rules>
        <rule name="TinoTelebot" stopProcessing="true">
          <match url=".*" />
          <action type="Rewrite" url="dist/index.js" />
        </rule>
      </rules>
    </rewrite>
    <iisnode watchedFiles="web.config;dist\*.js" />
  </system.webServer>
</configuration>
